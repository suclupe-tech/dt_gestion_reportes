<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_stock_quant_dt_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">

                    <t t-set="total_qty" t-value="sum([q.quantity for q in docs])"/>
                    <t t-set="total_models" t-value="len(set([q.product_id.product_tmpl_id.id for q in docs]))"/>
                    <t t-set="with_stock" t-value="sum([1 for q in docs if q.quantity &gt; 0])"/>
                    <t t-set="low_stock" t-value="sum([1 for q in docs if q.quantity &gt; 0 and q.quantity &lt; 10])"/>

                    <p><strong>Fecha:</strong> <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/></p>
                    <p><strong>Usuario:</strong> <span t-esc="user.name"/></p>
                    <p><strong>Almacén/Ubicación:</strong> <span t-esc="docs[0].location_id.display_name if len(docs.mapped('location_id')) == 1 else 'Varios'"/></p>

                    <h2 style="font-size:24px;font-weight:400;margin-bottom:18px;">Reporte de Stock</h2>

                    <table class="table table-sm" style="margin-top:10px;margin-bottom:14px;border:1px solid #ddd;">
                        <tr style="background:#f2f2f2;">
                            <td style="text-align:center;padding:6px;"><strong>Total prendas</strong><br/><span t-esc="'%.2f' % total_qty"/></td>
                            <td style="text-align:center;padding:6px;"><strong>Total modelos</strong><br/><span t-esc="total_models"/></td>
                            <td style="text-align:center;padding:6px;"><strong>Con stock</strong><br/><span t-esc="with_stock"/></td>
                            <td style="text-align:center;padding:6px;"><strong>Stock bajo</strong><br/><span t-esc="low_stock"/></td>
                        </tr>
                    </table>

                    <table class="table table-sm">
                        <thead>
                            <tr style="background-color:#123b63;">
                                <th style="color:white;padding:6px;">Fecha</th>
                                <th style="color:white;padding:6px;">Código</th>
                                <th style="color:white;padding:6px;">Producto</th>
                                <th style="color:white;padding:6px;">Ubicación</th>
                                <th class="text-end" style="color:white;padding:6px;">Cantidad</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="docs" t-as="q">
                                <td><span t-esc="q.in_date.strftime('%d/%m/%Y') if q.in_date else ''"/></td>
                                <td><span t-esc="q.product_id.default_code or ''"/></td>
                                <td><span t-field="q.product_id"/></td>
                                <td><span t-field="q.location_id"/></td>
                                <td class="text-end"><span t-esc="'%.2f' % q.quantity"/></td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr style="border-top:1px solid #333;">
                                <td colspan="4"><strong>TOTAL PRENDAS</strong></td>
                                <td class="text-end"><strong><span t-esc="'%.2f' % total_qty"/></strong></td>
                            </tr>
                        </tfoot>
                    </table>

                </div>
            </t>
        </t>
    </template>
</odoo>