<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="external_layout_dt">

        <div class="header"
                style="margin-bottom:0;padding-bottom:0;border:none;">

            <div style="display:flex; align-items:center;margin-bottom:6px; border:none;">
                <div style="width:75px;border:none;">
                    <img t-if="res_company.logo"
                            t-att-src="image_data_uri(res_company.logo)"
                            style="max-height:50px;"/>
                </div>
                <div style="margin-left:10px;border:none;">
                    <div style="font-size:17px; font-weight:bold;color:#0b2f5b;">
                        <span t-esc="res_company.name"/>
                    </div>
                    <div style="font-size:11px;">
                        <span t-esc="res_company.partner_id.street or ''"/>
                    </div>
                    <div style="font-size:11px;">
                        RUC:
                        <span t-esc="res_company.vat"/>
                    </div>
                </div>
            </div>
            <hr style="margin:2px 0 0 0;"/>
        </div>
        <div style="height:20;"></div>
        <div class="article">
            <t t-out="0"/>
        </div>
        <div class="footer">
            <div style="
                border-top:1px solid #ddd;
                padding-top:5px;
                font-size:10px;
                text-align:right;">

                Página
                <span class="page"/>
                /
                <span class="topage"/>
            </div>
        </div>
    </template>
</odoo>