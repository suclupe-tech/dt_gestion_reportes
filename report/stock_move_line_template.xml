<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_stock_move_line_template">
        <t t-call="web.html_container">
            <t t-call="dt_gestion_reportes.external_layout_dt">

                <div class="page">

                    <h2 style="text-align:center;">
                        REPORTE HISTORIAL MOVIMIENTOS
                    </h2>
                    <table style="margin-bottom:10px;font-size:13px;">
                        <tr>
                            <td><strong>Fecha:</strong></td>
                            <td>
                                <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Usuario:</strong></td>
                            <td><span t-esc="user.name"/></td>
                        </tr>
                    </table>
                    <table class="table table-sm">
                        <thead>
                            <tr style="background:#123b63;">
                                <th style="color:white;">Producto</th>
                                <th style="color:white;">Origen</th>
                                <th style="color:white;">Destino</th>
                                <th style="color:white;">Cantidad</th>
                                <th style="color:white;">Fecha</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr t-foreach="docs" t-as="m">
                                <td>
                                    <span t-esc="m.product_id.display_name"/>
                                </td>
                                <td>
                                    <span t-esc="m.dt_location_label(m.location_id)"/>
                                </td>

                                <td>
                                    <span t-esc="m.dt_location_label(m.location_dest_id)"/>
                                </td>
                                <td>
                                    <span t-esc="m.quantity"/>
                                </td>
                                <td>
                                    <span t-esc="m.date.strftime('%d/%m/%Y') if m.date else ''"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    <hr/>
                    <table style="width:100%;margin-top:10px;font-size:14px;">
                        <tr>
                            <td>
                                <strong>Total movimientos:</strong>
                                <span t-esc="len(docs)"/>
                            </td>
                            <td style="text-align:right;">
                                <strong>Total cantidad:</strong>
                                <span t-esc="'%.2f' % sum(docs.mapped('quantity'))"/>
                            </td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>